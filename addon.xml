<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.audio.songloft" name="Songloft" version="1.0.3" provider-name="altman08">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.xbmcswift2" version="2.4.0"/>
    <import addon="script.module.requests" version="2.19.1"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="addon.py">
    <provides>audio</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <language>zh</language>
    <assets>
      <icon>icon.png</icon>
    </assets>
    <summary lang="zh_CN">Songloft 自托管音乐播放器</summary>
    <description lang="zh_CN">通过 Kodi 播放 Songloft 自托管音乐服务器上的音乐。支持歌曲库浏览、歌单播放、搜索等功能。</description>
    <news>
      v1.0.3 - 修复设置页出现音频解码器等无关配置项的问题
      v1.0.2 - 新增「播放全部」功能，可跨分页加载全部歌曲到播放列表
      v1.0.1 - 修复播放时专辑封面不显示的问题
      v1.0.0 - 初始版本：歌曲库浏览、歌单播放、搜索
    </news>
  </extension>
</addon>
